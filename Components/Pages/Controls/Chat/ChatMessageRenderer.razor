@using Markdig

<div class="chat-markdown">
    @((MarkupString)RenderedHtml)
</div>

@code {
    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    [Parameter, EditorRequired]
    public string Content { get; set; } = "";

    private string RenderedHtml =>
        string.IsNullOrEmpty(Content)
            ? ""
            : Markdig.Markdown.ToHtml(Content, Pipeline);
}

<style>
    .chat-markdown {
        font-size: 0.95rem;
        line-height: 1.6;
        word-wrap: break-word;
    }

    .chat-markdown h1,
    .chat-markdown h2,
    .chat-markdown h3,
    .chat-markdown h4 {
        margin-top: 0.8em;
        margin-bottom: 0.4em;
        font-weight: 600;
    }

    .chat-markdown h1 { font-size: 1.4em; }
    .chat-markdown h2 { font-size: 1.25em; }
    .chat-markdown h3 { font-size: 1.1em; }

    .chat-markdown p {
        margin: 0.4em 0;
    }

    .chat-markdown ul,
    .chat-markdown ol {
        padding-left: 1.5em;
        margin: 0.4em 0;
    }

    .chat-markdown li {
        margin-bottom: 0.2em;
    }

    .chat-markdown code {
        background: rgba(0, 0, 0, 0.06);
        padding: 0.15em 0.35em;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: Consolas, 'Courier New', monospace;
    }

    .chat-markdown pre {
        background: #1e1e1e;
        color: #d4d4d4;
        padding: 0.8em 1em;
        border-radius: 6px;
        overflow-x: auto;
        margin: 0.5em 0;
    }

    .chat-markdown pre code {
        background: transparent;
        padding: 0;
        color: inherit;
    }

    .chat-markdown blockquote {
        border-left: 3px solid #ccc;
        margin: 0.5em 0;
        padding: 0.3em 0.8em;
        color: #555;
        background: rgba(0, 0, 0, 0.03);
    }

    .chat-markdown table {
        border-collapse: collapse;
        width: 100%;
        margin: 0.5em 0;
        font-size: 0.9em;
    }

    .chat-markdown th,
    .chat-markdown td {
        border: 1px solid #ddd;
        padding: 0.4em 0.6em;
        text-align: left;
    }

    .chat-markdown th {
        background: #f5f5f5;
        font-weight: 600;
    }

    .chat-markdown tr:nth-child(even) {
        background: #fafafa;
    }

    .chat-markdown hr {
        border: none;
        border-top: 1px solid #ddd;
        margin: 0.8em 0;
    }

    .chat-markdown a {
        color: #0366d6;
        text-decoration: none;
    }

    .chat-markdown a:hover {
        text-decoration: underline;
    }

    .chat-markdown strong {
        font-weight: 600;
    }
</style>
